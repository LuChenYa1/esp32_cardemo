# 主程序CMakeLists.txt配置
# 注意: 只能包含一个包含 app_main() 的文件
# 根据需要选择使用哪个主程序：
# - main.c: 原始主程序
# - main_watchdog_fix.c: 看门狗修复版（推荐）
# - main_diagnostic.c: 诊断程序
# - main_test_no_turn_detect.c: 传感器测试
# - main_line_following_example.c: 完整功能示例

idf_component_register(SRCS "sensor_test_multitask.c" "gpio_drive_test.c" "main_multitask.c" "main_integrated_test.c" "main_display_test.c" "main_adc_sampling_test.c" "main_pd_test.c" "main_cartest.c" "main_servo_test.c" "main.c" "line_following.c" "turn_detection.c"
                    INCLUDE_DIRS "."
