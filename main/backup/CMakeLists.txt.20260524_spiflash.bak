# 主程序CMakeLists.txt配置
# 注意: 只能包含一个包含 app_main() 的文件
# 根据需要选择使用哪个主程序：
# - main.c: 原始主程序
# - main_watchdog_fix.c: 看门狗修复版（推荐）
# - main_diagnostic.c: 诊断程序
# - main_test_no_turn_detect.c: 传感器测试
# - main_line_following_example.c: 完整功能示例

idf_component_register(SRCS "main.c" "line_following.c" "turn_detection.c"
                    INCLUDE_DIRS "."
                    REQUIRES 
                    dht11 
                    wireless 
                    esp_timer 
                    tm1637 
                    ssax1 
                    ssdx 
                    pwm 
                    pcf8574 
                    encoder 
                    spiflash 
                    485servo 
                    uart 
                    gray_sensor
                    pcf_buzzer 
                    timer_system 
                    turn_detector 
                    pd_controller 
                    turn_statemachine 
                    display_task 
                    servo_task 
                    voice_module 
                    camera_protocol 
                    ir_obstacle 
                    traffic_light 
                    five_way_gray_i2c 
                    hc-sr04 
                    board_config )
