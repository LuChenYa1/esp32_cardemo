#include "line_following.h"
#include "gray_sensor.h"
#include "pwm.h"
#include "encoder.h"
#include "turn_detection.h"
#include "esp_log.h"
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include <math.h>

static const char *TAG = "LINE_FOLLOWING";

// PD控制器状态
static float last_error = 0.0f;

// 误差死区
#define ERROR_DEAD_ZONE 30

/**
 * @brief 初始化巡线控制模块
 */
void line_following_init(void)
{
    ESP_LOGI(TAG, "初始化巡线控制模块...");

    // 初始化灰度传感器
    gray_sensor_init();

    // 初始化PWM电机控制
    ledc_init();

    ESP_LOGI(TAG, "巡线控制模块初始化完成");
}

/**
 * @brief 车辆前进
 */
void car_move_forward(int16_t speed)
{
    // 所有车轮正向转动
    set_motor_speed(speed, 0);  // 电机1
    set_motor2_speed(speed, 0); // 电机2
    set_motor3_speed(speed, 0); // 电机3
    set_motor4_speed(speed, 0); // 电机4
}

/**
 * @brief 车辆后退
 */
void car_move_backward(int16_t speed)
{
    // 所有车轮反向转动
    set_motor_speed(0, speed);  // 电机1
    set_motor2_speed(0, speed); // 电机2
    set_motor3_speed(0, speed); // 电机3
    set_motor4_speed(0, speed); // 电机4
}

/**
 * @brief 车辆左转（原地）
 */
void car_turn_left(int16_t speed)
{
    // 左轮反转，右轮正转
    set_motor_speed(speed, 0);  // 电机1 - 右前轮正转
    set_motor2_speed(speed, 0); // 电机2 - 左前轮反转
    set_motor3_speed(0, speed); // 电机3 - 右后轮正转
    set_motor4_speed(0, speed); // 电机4 - 左后轮反转
    // set_motor_speed(speed, 0);      // 电机1 - 右前轮正转
    // set_motor2_speed(0, speed);     // 电机2 - 左前轮反转
    // set_motor3_speed(speed, 0);     // 电机3 - 右后轮正转
    // set_motor4_speed(0, speed);     // 电机4 - 左后轮反转
}

/**
 * @brief 车辆右转（原地）
 */
void car_turn_right(int16_t speed)
{
    // 左轮正转，右轮反转
    set_motor_speed(0, speed);  // 电机1 - 右前轮反转
    set_motor2_speed(0, speed); // 电机2 - 左前轮正转
    set_motor3_speed(speed, 0); // 电机3 - 右后轮反转
    set_motor4_speed(speed, 0); // 电机4 - 左后轮正转
    // set_motor_speed(0, speed);      // 电机1 - 右前轮反转
    // set_motor2_speed(speed, 0);     // 电机2 - 左前轮正转
    // set_motor3_speed(0, speed);     // 电机3 - 右后轮反转
    // set_motor4_speed(speed, 0);     // 电机4 - 左后轮正转
}

/**
 * @brief 车辆停止
 */
void car_stop(void)
{
    set_motor_speed(0, 0);
    set_motor2_speed(0, 0);
    set_motor3_speed(0, 0);
    set_motor4_speed(0, 0);
}

/**
 * @brief 设置所有车轮速度
 */
void set_all_wheels(int16_t front_left, int16_t front_right,
                    int16_t rear_left, int16_t rear_right)
{
    // 根据速度正负设置电机方向
    if (front_right >= 0)
    {
        set_motor_speed(front_right, 0);
    }
    else
    {
        set_motor_speed(0, -front_right);
    }

    if (front_left >= 0)
    {
        set_motor2_speed(front_left, 0);
    }
    else
    {
        set_motor2_speed(0, -front_left);
    }

    if (rear_right >= 0)
    {
        set_motor3_speed(rear_right, 0);
    }
    else
    {
        set_motor3_speed(0, -rear_right);
    }

    if (rear_left >= 0)
    {
        set_motor4_speed(rear_left, 0);
    }
    else
    {
        set_motor4_speed(0, -rear_left);
    }
}

/**
 * @brief PD控制巡线（使用传入的传感器值）
 *
 * @param left_raw 左传感器原始值
 * @param right_raw 右传感器原始值
 * @param speed 基础速度 (0-1023，直接对应硬件占空比)
 * @param kp 比例系数
 * @param kd 微分系数
 */
void line_following_pd_control_with_values(uint16_t left_raw, uint16_t right_raw, 
                                           uint16_t speed, float kp, float kd)
{
    float left_norm, right_norm;
    float error, output;

    // 归一化传感器值 (0=黑线, 1=白色)
    left_norm = (float)(left_raw - 1476) / (float)(4095 - 1476);
    right_norm = (float)(right_raw - 1546) / (float)(4095 - 1546);
    
    // 限制在0-1范围内
    if (left_norm < 0.0f) left_norm = 0.0f;
    if (left_norm > 1.0f) left_norm = 1.0f;
    if (right_norm < 0.0f) right_norm = 0.0f;
    if (right_norm > 1.0f) right_norm = 1.0f;

    // 计算误差 (白底黑线模式)
    // 右传感器值大 - 左传感器值大 = 正误差（需要右转）
    error = 510.0f * (right_norm - left_norm);

    // 误差死区处理
    if (fabsf(error) < ERROR_DEAD_ZONE)
    {
        error = 0.0f;
    }

    // PD控制输出
    output = kp * error + kd * (error - last_error);

    // 限制输出范围（不超过基础速度）
    if (output > speed)
        output = speed;
    if (output < -speed)
        output = -speed;

    // 计算左右轮速度
    int16_t left_speed = speed - (int16_t)output;
    int16_t right_speed = speed + (int16_t)output;

    // 限制速度范围在0-1023之间（硬件最大占空比）
    if (left_speed < 0)
        left_speed = 0;
    if (left_speed > PWM_MAX_DUTY)
        left_speed = PWM_MAX_DUTY;
    if (right_speed < 0)
        right_speed = 0;
    if (right_speed > PWM_MAX_DUTY)
        right_speed = PWM_MAX_DUTY;

    // 应用到车轮
    set_all_wheels(right_speed, right_speed, left_speed, left_speed);
    // set_all_wheels(left_speed, right_speed, left_speed, right_speed);

    // 更新上次误差
    last_error = error;
}

/**
 * @brief 简单巡线（无PID）
 */
void line_following_simple(uint16_t speed)
{
    float left_norm, right_norm;

    // 读取归一化传感器值
    gray_sensor_read_both_normalized(&left_norm, &right_norm);

    // 检查数据有效性
    if (left_norm < 0.0f || right_norm < 0.0f)
    {
        // 数据无效，停止
        car_stop();
        return;
    }

    // 阈值判断（0.5为黑白分界）
    bool left_on_black = (left_norm < 0.5f);
    bool right_on_black = (right_norm < 0.5f);

    if (left_on_black && right_on_black)
    {
        // 两个都在黑线上 - 直行
        car_move_forward(speed);
    }
    else if (left_on_black && !right_on_black)
    {
        // 左传感器在黑线上 - 左转
        set_all_wheels(speed / 3, speed, speed / 3, speed);
    }
    else if (!left_on_black && right_on_black)
    {
        // 右传感器在黑线上 - 右转
        set_all_wheels(speed, speed / 3, speed, speed / 3);
    }
    else
    {
        // 都不在黑线上 - 停止
        car_stop();
    }
}

/**
 * @brief 执行左转90度
 */
void execute_left_turn(uint16_t speed)
{
    ESP_LOGI(TAG, "执行左转90度");

    uint16_t left_raw, right_raw;
    const gray_sensor_calibration_t *right_cal = gray_sensor_get_calibration(GRAY_SENSOR_RIGHT);

    uint16_t right_threshold = (right_cal->white_value + right_cal->black_value) / 2;

    // 第一阶段：强制转够最小角度
    uint8_t turn_timeout = 0;
    while (turn_timeout < 100)
    { // 100 * 5ms = 500ms
        car_turn_left(speed);
        vTaskDelay(pdMS_TO_TICKS(5));
        turn_timeout++;
    }

    // 第二阶段：继续转到右传感器找到新黑线
    turn_timeout = 0;
    while (turn_timeout < 80)
    {
        if (gray_sensor_get_current_values(&left_raw, &right_raw))
        {
            if (right_raw < right_threshold)
            {
                // 找到黑线，退出循环
                break;
            }
        }
        car_turn_left((uint16_t)(speed * 0.6f));
        vTaskDelay(pdMS_TO_TICKS(5));
        turn_timeout++;
    }

    // 停止
    car_stop();
    vTaskDelay(pdMS_TO_TICKS(50));

    // 微调
    car_turn_right((uint16_t)(speed * 0.6f));
    vTaskDelay(pdMS_TO_TICKS(200));
    car_stop();

    // 重置转弯状态
    turn_detection_reset();

    ESP_LOGI(TAG, "左转完成");
}

/**
 * @brief 执行右转90度
 */
void execute_right_turn(uint16_t speed)
{
    uint16_t left_raw, right_raw;

    uint16_t left_threshold = (4095 + 1150) / 2;
    uint16_t right_threshold = (4095 + 1150) / 2;

    // 第一阶段：快速转到左传感器离开黑线
    uint8_t turn_timeout = 0;
    while (turn_timeout < 30)
    {
        if (gray_sensor_get_current_values(&left_raw, &right_raw))
        {
            if (left_raw >= left_threshold)
            {
                // 左传感器已离开黑线
                break;
            }
        }
        car_turn_right(512); // 约50%占空比
        vTaskDelay(pdMS_TO_TICKS(5));
        turn_timeout++;
    }

    // 第二阶段：继续转到右传感器找到新黑线
    while (true)
    {
        if (gray_sensor_get_current_values(&left_raw, &right_raw))
        {
            if (right_raw < right_threshold)
            {
                // 右传感器找到黑线
                break;
            }
        }
        car_turn_right(512); // 约50%占空比
        vTaskDelay(pdMS_TO_TICKS(5));
    }

    // 停止
    car_stop();
    vTaskDelay(pdMS_TO_TICKS(50));

    // 微调
    car_turn_right(512); // 约50%占空比
    vTaskDelay(pdMS_TO_TICKS(15));
    car_stop();
    vTaskDelay(pdMS_TO_TICKS(50));

    // 重置转弯状态
    turn_detection_reset();

    // ESP_LOGI(TAG, "右转完成");
}

/**
 * @brief 执行十字路口处理
 */
void execute_crossroad(uint16_t speed)
{
    ESP_LOGI(TAG, "检测到十字路口，执行右转");

    // 停止
    car_stop();
    vTaskDelay(pdMS_TO_TICKS(100));

    // 后退一点距离
    car_move_backward(614); // 约60%占空比
    vTaskDelay(pdMS_TO_TICKS(200));
    car_stop();
    vTaskDelay(pdMS_TO_TICKS(100));

    // 执行右转
    execute_right_turn(speed);
}

/**
 * @brief 带转弯检测的巡线
 */
void line_following_with_turns(uint16_t speed, float kp, float kd)
{
    // 检查是否有转弯请求
    if (turn_detection_is_turning())
    {
        uint8_t turn_type = turn_detection_get_type();

        switch (turn_type)
        {
        case 1: // 左转
            execute_left_turn(speed);
            break;

        case 2: // 右转
            execute_right_turn(speed);
            break;

        case 3: // 十字路口
            execute_crossroad(speed);
            break;

        default:
            vTaskDelay(pdMS_TO_TICKS(5)); // 默认延时
            break;
        }
    }
    else
    {
        // 正常PID巡线
        line_following_pd_control(speed, kp, kd);
        vTaskDelay(pdMS_TO_TICKS(5));
    }
}

/**
 * @brief 执行右转90度（简化版本）
 */
void execute_right_turn_simple(uint16_t speed)
{
    ESP_LOGI(TAG, "执行右转90度");
    
    uint16_t left_raw, right_raw;
    uint16_t left_threshold = (4095 + 1476) / 2;
    uint16_t right_threshold = (4095 + 1546) / 2;
    
    // 第一阶段：快速转到左传感器离开黑线
    uint8_t turn_timeout = 0;
    while (turn_timeout < 30)
    {
        if (gray_sensor_read_both_raw_direct(&left_raw, &right_raw))
        {
            if (left_raw >= left_threshold)
            {
                // 左传感器已离开黑线
                break;
            }
        }
        car_turn_right(512); // 约50%占空比
        vTaskDelay(pdMS_TO_TICKS(5));
        turn_timeout++;
    }
    
    // 第二阶段：继续转到右传感器找到新黑线
    while (true)
    {
        if (gray_sensor_read_both_raw_direct(&left_raw, &right_raw))
        {
            if (right_raw < right_threshold)
            {
                // 右传感器找到黑线
                break;
            }
        }
        car_turn_right(512); // 约50%占空比
        vTaskDelay(pdMS_TO_TICKS(5));
    }
    
    // 停止
    car_stop();
    vTaskDelay(pdMS_TO_TICKS(50));
    
    // 微调
    car_turn_right(512); // 约50%占空比
    vTaskDelay(pdMS_TO_TICKS(15));
    car_stop();
    vTaskDelay(pdMS_TO_TICKS(50));
    
    ESP_LOGI(TAG, "右转完成");
}
