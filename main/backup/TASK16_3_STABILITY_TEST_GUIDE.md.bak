## 自动化监控脚本

### Python监控脚本

创建 `monitor_stability.py` 脚本，自动记录系统状态：

```python
#!/usr/bin/env python3
"""
ESP32稳定性测试监控脚本
自动解析串口日志，记录系统状态
"""

import serial
import re
import time
import csv
from datetime import datetime

# 配置
SERIAL_PORT = '/dev/ttyUSB0'  # 根据实际情况修改
BAUD_RATE = 115200
LOG_FILE = f'stability_test_{datetime.now().strftime("%Y%m%d_%H%M%S")}.csv'

# 正则表达式匹配系统状态日志
PATTERN_STATUS = r'系统状态 - Timer0: (\d+)次/5s, Timer1: (\d+)次/5s, ADC错误: (\d+)次'
PATTERN_MEMORY = r'空闲堆内存: (\d+) 字节'

def main():
    # 打开串口
    ser = serial.Serial(SERIAL_PORT, BAUD_RATE, timeout=1)
    
    # 创建CSV文件
    with open(LOG_FILE, 'w', newline='') as csvfile:
        writer = csv.writer(csvfile)
        writer.writerow(['时间戳', 'Timer0计数', 'Timer1计数', 'ADC错误', '空闲堆内存'])
        
        print(f"开始监控，日志保存到: {LOG_FILE}")
        print("按Ctrl+C停止监控")
        
        timer0_count = 0
        timer1_count = 0
        adc_error = 0
        free_heap = 0
        
        try:
            while True:
                line = ser.readline().decode('utf-8', errors='ignore').strip()
                
                # 匹配系统状态
                match_status = re.search(PATTERN_STATUS, line)
                if match_status:
                    timer0_count = int(match_status.group(1))
                    timer1_count = int(match_status.group(2))
                    adc_error = int(match_status.group(3))
                
                # 匹配内存信息
                match_memory = re.search(PATTERN_MEMORY, line)
                if match_memory:
                    free_heap = int(match_memory.group(1))
                    
                    # 记录到CSV
                    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                    writer.writerow([timestamp, timer0_count, timer1_count, adc_error, free_heap])
                    csvfile.flush()
                    
                    # 打印到控制台
                    print(f"[{timestamp}] Timer0: {timer0_count}, Timer1: {timer1_count}, "
                          f"ADC错误: {adc_error}, 内存: {free_heap}")
                    
                    # 检查异常
                    if timer0_count < 4500 or timer0_count > 5500:
                        print(f"  ⚠️  警告：Timer0频率异常！")
                    if timer1_count < 450 or timer1_count > 550:
                        print(f"  ⚠️  警告：Timer1频率异常！")
                    if adc_error > 50:
                        print(f"  ⚠️  警告：ADC错误率过高！")
                
        except KeyboardInterrupt:
            print("\n监控已停止")
        finally:
            ser.close()

if __name__ == '__main__':
    main()
```

### 使用方法

```bash
# 1. 安装依赖
pip install pyserial

# 2. 修改串口配置
# 编辑 monitor_stability.py，修改 SERIAL_PORT

# 3. 运行监控脚本
python3 monitor_stability.py

# 4. 让脚本在后台运行24小时
nohup python3 monitor_stability.py &

# 5. 查看实时日志
tail -f nohup.out
```

